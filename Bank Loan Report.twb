      <aliases enabled='yes' />
      <column caption='Total Loan Applications' datatype='integer' name='[Calculation_0201261855395840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='MTD Loan Applications' datatype='integer' name='[Calculation_0334028018352129]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;DATEDIFF(&apos;month&apos;, [issue_date], {MAX([issue_date])})=0&#13;&#10;THEN&#13;&#10;[id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='MoM Loan Applications' datatype='real' name='[Calculation_0334028025380867]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0334028018352129] - [MTD Total Loan Applications (copy)_0334028024827906])&#13;&#10;/&#13;&#10;[MTD Total Loan Applications (copy)_0334028024827906]' />
      </column>
      <column caption='Total Funded Amount' datatype='integer' name='[Calculation_0334028028841988]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([loan_amount])' />
      </column>
      <column caption='MoM Total Funded Amount' datatype='real' name='[Calculation_0334028032806920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Loan Applications (copy)_0334028029992965]-[MTD Total Funded Amount (copy)_0334028031545351])/[MTD Total Funded Amount (copy)_0334028031545351]' />
      </column>
      <column caption='Total Amount Received' datatype='integer' name='[Calculation_0334028034973705]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_payment])' />
      </column>
      <column caption='MoM Amount Received' datatype='real' name='[Calculation_0334028036984844]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Total Funded Amount (copy)_0334028035948554]-[MTD Total Amount Received (copy)_0334028036780043])/[MTD Total Amount Received (copy)_0334028036780043]' />
      </column>
      <column caption='Avg Interest rate' datatype='real' name='[Calculation_0334028037996557]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([int_rate])' />
      </column>
      <column caption='MoM Avg Int Rate' datatype='real' name='[Calculation_0334028039573520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Loan Applications (copy)_0334028038688782] - [MTD Avg INT Rate (copy)_0334028039327759])/[MTD Avg INT Rate (copy)_0334028039327759]' />
      </column>
      <column caption='Avg DTI' datatype='real' name='[Calculation_0334028040609809]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([dti])' />
      </column>
      <column caption='Mom Avg DTI' datatype='real' name='[Calculation_0334028041830421]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Avg INT Rate (copy)_0334028041043986]-[MTD Avg DTI (copy)_0334028041564180])/[MTD Avg DTI (copy)_0334028041564180]' />
      </column>
      <column caption='Good Loan %' datatype='real' name='[Calculation_0334028106125341]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Good v Bad Loan] = &apos;Good Loan&apos; THEN [id] END)&#13;&#10;/&#13;&#10;COUNT([id])' />
      </column>
      <column caption='Good Loan Applications' datatype='integer' name='[Calculation_0334028109840414]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Good v Bad Loan]= &apos;Good Loan&apos; THEN [id] END)' />
      </column>
      <column caption='Dynamic Measure' datatype='integer' name='[Calculation_0334028152393766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &apos;Total Loan Applications&apos; THEN [Calculation_0201261855395840]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;Total Funded Amount&apos; THEN [Calculation_0334028028841988]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;Total Amount Received&apos; THEN [Calculation_0334028034973705]&#13;&#10;END' />
      </column>
      <column caption='Bad Loan % ' datatype='real' name='[Good Loan % (copy)_0334028119224354]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Good v Bad Loan] = &apos;Bad Loan&apos; THEN [id] END)&#13;&#10;/&#13;&#10;COUNT([id])' />
      </column>
      <column caption='Bad Loan Amount Received ' datatype='integer' name='[Good Loan Amount Received (copy)_0334028123533349]' role='measure' type='quantitative'>
