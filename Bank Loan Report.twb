      <table>
        <view>
          <datasources>
            <datasource caption='financial_loan' name='federated.1i30kpc08uvbjp1e9winl1uzi4ri' />
          </datasources>
          <datasource-dependencies datasource='federated.1i30kpc08uvbjp1e9winl1uzi4ri'>
            <column caption='Bad Loan Funded Amount ' datatype='integer' name='[Good Loan Funded Amount (copy)_0334028122767396]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Good v Bad Loan]= &apos;Bad Loan&apos; THEN [loan_amount] END)' />
            </column>
            <column datatype='string' name='[Good v Bad Loan]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[loan_status]' new-bin='true'>
